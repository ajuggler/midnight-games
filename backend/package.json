{
  "name": "game-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/server.ts",
    "build:frontend": "npm --prefix ../frontend run build",
    "dev:frontend": "npm --prefix ../frontend run build:watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "express": "^4",
    "express-session": "^1"
  },
  "devDependencies": {
    "@types/express": "^4",
    "@types/express-session": "^1",
    "nodemon": "^3.1.14",
    "ts-node": "^10",
    "typescript": "^5"
  }
}
